{
    "name": "marcohoutmandev/rmt-versioning",
    "description": "Extension for the RMT package. Used for adding custom versioning + changelog handeling. ",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/marcohoutmandev/rmt-versioning",
    "version": "1.2.4",
    "keywords": [
        "RMT",
        "Versioning"
    ],
    "authors": [
        {
            "name": "Marco Houtman",
            "email": "post@marcohoutman.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "MHD\\RmtVersioning\\": "src/"
        }
    },
    "require": {
        "php": "~8.4.0 || ~8.5.0",
        "liip/rmt": "^1.9"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpmd/phpmd": "^2.15",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "check-code": [
            "php ./vendor/bin/phpcs src",
            "php ./vendor/bin/phpstan analyse src --ansi",
            "php -d error_reporting=$(php -r 'echo E_ERROR | E_WARNING;') ./vendor/bin/phpmd src text phpmd.xml"
        ]
    }
}